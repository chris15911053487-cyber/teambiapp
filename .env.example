# Teambition API 配置
# 复制此文件为 .env 并填写你的配置

# 从 Teambition 开放平台获取的 Token
TEAMBITION_TOKEN=your_token_here

# 企业 ID
TEAMBITION_TENANT_ID=your_tenant_id_here

# --- FastAPI 后端（apps/backend）可选 ---
# 企业列表 JSON（勿提交真实密钥到公开仓库）
# TB_COMPANY_PROFILES_JSON=[{"name":"示例公司","app_id":"","app_secret":"","tenant_id":""}]
# REDIS_URL=redis://localhost:6379/0
# JWT_SECRET=
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Next.js 前端（apps/frontend/.env.local）---
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
